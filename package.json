{
  "name": "sciovirtual-codebusters",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ScioVirtual Advanced Codebusters course site: static, with interactive cipher solvers and a local question generator.",
  "bin": {
    "scio": "tools/cli.mjs"
  },
  "scripts": {
    "cli": "node tools/cli.mjs",
    "start": "python3 -m http.server 8000",
    "serve": "npx --yes serve -l 8000 .",
    "add:question": "node tools/add-question.mjs",
    "add:questionpage": "node tools/add-questionpage.mjs",
    "add:relay": "node tools/add-relay.mjs",
    "add:relay-round": "node tools/add-relay-round.mjs",
    "add:page": "node tools/add-page.mjs",
    "add:homework": "node tools/add-homework.mjs",
    "add:recording": "node tools/add-recording.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
